        "coreSkill": {
            "desc": [
                "<div class=\"flex flex-col gap-2.5 text-sm leading-4\"><!--[--><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Core Passive: Entangle<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->Upon entering <span style=\"color: #FFFFFF\">Binding Seal</span>, Evelyn's CRIT Rate increases by <span style=\"color: #2BAD00\">25%</span>. After leaving <span style=\"color: #FFFFFF\">Binding Seal</span>, she retains the buff for 10s. If Evelyn switches to another character while in <span style=\"color: #FFFFFF\">Binding Seal</span>, she will automatically follow up with <span style=\"color: #FFFFFF\">Special Attack: Binding Sunder - First Form</span>.<!-- --></span><!--]--><!-- --></p></div><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Additional Ability: Ambush Point<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->When another character in your squad is a <span style=\"color: #FFFFFF\">Stun</span> or <span style=\"color: #FFFFFF\">Support</span> character:<br/>Evelyn's <span style=\"color: #FFFFFF\">Chain Attack</span> and <span style=\"color: #FFFFFF\">Ultimate</span> DMG increases by 30%. When Evelyn's CRIT Rate is at or over 80%, the DMG multiplier for her <span style=\"color: #FFFFFF\">Chain Attack: Lunalux - Snare</span>, <span style=\"color: #FFFFFF\">Ultimate: Lunalux Garrote - Timbre</span> and <span style=\"color: #FFFFFF\">Ultimate: Lunalux Garrote - Shadow</span> increases to 125% of the original value.<!-- --></span><!--]--><!-- --></p></div><!--]--><!-- --></div>"
            ],
            "coreGrowthStat": {
                "20101": 48000,
                "12101": 25
            }
        }
    },
