            "0": {
                "skillId": 0,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Turbo Volt<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Unleashes up to 4 slashes. The first 3 hits deal <span style=\"color: #F0D12B\">Physical DMG</span>, the 4th hit deals <span style=\"color: #2EB6FF\">Electric DMG</span>.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Unleashes up to 4 slashes. The first 3 hits deal <span style=\"color: #F0D12B\">Physical DMG</span>, the 4th hit deals <span style=\"color: #2EB6FF\">Electric DMG</span>.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Thunderbolt<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->After unleashing the 3rd hit of the <span style=\"color: #FFFFFF\">Basic Attack</span>, hold down or pause for a short while, and then press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Unleashes a downward strike that deals <span style=\"color: #2EB6FF\">Electric DMG</span>.<br/>Anti-Interrupt level is increased while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->After unleashing the 3rd hit of the <span style=\"color: #FFFFFF\">Basic Attack</span>, hold down or pause for a short while, and then press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Unleashes a downward strike that deals <span style=\"color: #2EB6FF\">Electric DMG</span>.<br/>Anti-Interrupt level is increased while using this skill.<!-- --></span>"
