            "2": {
                "skillId": 2,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Dodge: Bunny Hop<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/5161803192951478865_250_13063804.webp\"/> to activate:<br/>A quick dash dodge.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/5161803192951478865_250_13063804.webp\"/> to activate:<br/>A quick dash dodge.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Dash Attack: Bouncing Dash<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> during a dodge to activate:<br/>Slashes forward, dealing <span style=\"color: #F0D12B\">Physical DMG</span> and <span style=\"color: #98EFF0\">Ice DMG</span>.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> during a dodge to activate:<br/>Slashes forward, dealing <span style=\"color: #F0D12B\">Physical DMG</span> and <span style=\"color: #98EFF0\">Ice DMG</span>.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Dodge Counter: Swift Blink<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> during a <span style=\"color: #FFFFFF\">Perfect Dodge</span> to activate:<br/>Performs a falling slash ahead, dealing <span style=\"color: #98EFF0\">Ice DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> during a <span style=\"color: #FFFFFF\">Perfect Dodge</span> to activate:<br/>Performs a falling slash ahead, dealing <span style=\"color: #98EFF0\">Ice DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>"
                ],
