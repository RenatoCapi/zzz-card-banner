            "3": {
                "skillId": 3,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Chain Attack: Tempest of Frosty Petals<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Summons her mech for protection, then launches cannon shots and a barrage of missiles, dealing massive <span style=\"color: #2EB6FF\">Electric DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Summons her mech for protection, then launches cannon shots and a barrage of missiles, dealing massive <span style=\"color: #2EB6FF\">Electric DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Ultimate: Clockwork Garden - Bloom!<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating is at <span style=\"color: #FFFFFF\">Maximum</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to activate:<br/>Seed will pilot the mech personally, raining down missiles and a meteor shower of rockets, then performing a jumping smash, dealing massive <span style=\"color: #2EB6FF\">Electric DMG</span>.<br/>After using this skill, accumulate 60 <span style=\"color: #FFFFFF\">Steel Charge</span>.<br/>Does not accumulate <span style=\"color: #FFFFFF\">Steel Charge</span> on hit.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating is at <span style=\"color: #FFFFFF\">Maximum</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to activate:<br/>Seed will pilot the mech personally, raining down missiles and a meteor shower of rockets, then performing a jumping smash, dealing massive <span style=\"color: #2EB6FF\">Electric DMG</span>.<br/>After using this skill, accumulate 60 <span style=\"color: #FFFFFF\">Steel Charge</span>.<br/>Does not accumulate <span style=\"color: #FFFFFF\">Steel Charge</span> on hit.<br/>Character is invulnerable while using this skill.<!-- --></span>"
                ],
