            "3": {
                "skillId": 3,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Chain Attack: \"Tipsy Concerto\"<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Use song to channel energy into a blast, dealing massive <span style=\"color: #FE437E\">Ether DMG</span>.<br/>Character is invulnerable while using this skill.<br/>A <span style=\"color: #ffffff\">Quick Assist</span> is triggered when this skill hits an enemy.<br/>After the skill, Astra Yao enters the <span style=\"color: #FFFFFF\">Idyllic Cadenza</span> state.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Use song to channel energy into a blast, dealing massive <span style=\"color: #FE437E\">Ether DMG</span>.<br/>Character is invulnerable while using this skill.<br/>A <span style=\"color: #ffffff\">Quick Assist</span> is triggered when this skill hits an enemy.<br/>After the skill, Astra Yao enters the <span style=\"color: #FFFFFF\">Idyllic Cadenza</span> state.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Ultimate: \"Fantasian Sonata\"<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating is at <span style=\"color: #FFFFFF\">Maximum</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to activate:<br/>Use song to channel energy into a blast, dealing massive <span style=\"color: #FE437E\">Ether DMG</span>, and restoring <span style=\"color: #2BAD00\">2950</span> HP to all squad members.<br/>Character is invulnerable while using this skill.<br/>A <span style=\"color: #ffffff\">Quick Assist</span> is triggered when this skill hits an enemy.<br/>After the skill, Astra Yao enters the <span style=\"color: #FFFFFF\">Idyllic Cadenza</span> state.<br/>After the skill, the next two <span style=\"color: #FFFFFF\">Quick Assists</span> will be replaced by <span style=\"color: #FFFFFF\">Chain Attacks</span>.<br/>Before all replacement chances are used up, a <span style=\"color: #FFFFFF\">Quick Assist</span> is triggered whenever any squad member hits an enemy with a <span style=\"color: #FFFFFF\">Chain Attack</span> or <span style=\"color: #FFFFFF\">Ultimate</span>.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating is at <span style=\"color: #FFFFFF\">Maximum</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to activate:<br/>Use song to channel energy into a blast, dealing massive <span style=\"color: #FE437E\">Ether DMG</span>, and restoring <span style=\"color: #2BAD00\">2950</span> HP to all squad members.<br/>Character is invulnerable while using this skill.<br/>A <span style=\"color: #ffffff\">Quick Assist</span> is triggered when this skill hits an enemy.<br/>After the skill, Astra Yao enters the <span style=\"color: #FFFFFF\">Idyllic Cadenza</span> state.<br/>After the skill, the next two <span style=\"color: #FFFFFF\">Quick Assists</span> will be replaced by <span style=\"color: #FFFFFF\">Chain Attacks</span>.<br/>Before all replacement chances are used up, a <span style=\"color: #FFFFFF\">Quick Assist</span> is triggered whenever any squad member hits an enemy with a <span style=\"color: #FFFFFF\">Chain Attack</span> or <span style=\"color: #FFFFFF\">Ultimate</span>.<!-- --></span>"
                ],
