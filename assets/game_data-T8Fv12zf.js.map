            "3": {
                "skillId": 3,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Chain Attack: Prank Assault<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Unleash a powerful strike on enemies in a small area ahead, dealing massive <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Gains 1 <span style=\"color: #FFFFFF\">Sugar Points</span> when used.<br/>A <span style=\"color: #FFFFFF\">Quick Assist</span> is triggered when this skill hits an enemy.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Unleash a powerful strike on enemies in a small area ahead, dealing massive <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Gains 1 <span style=\"color: #FFFFFF\">Sugar Points</span> when used.<br/>A <span style=\"color: #FFFFFF\">Quick Assist</span> is triggered when this skill hits an enemy.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Ultimate: Surrender or Suffer the Mischief<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating reaches Maximum, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to trigger:<br/>Unleash a powerful strike on enemies in a large area around the character, dealing massive <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Enemies hit with a heavy attack are inflicted with the <span style=\"color: #FFFFFF\">Sweet Scare</span> state.<br/>Upon activating this skill, other squad members gain <span style=\"color: #2BAD00\">25</span> Energy.<br/>Upon activating this skill, gain 2 <span style=\"color: #FFFFFF\">Sugar Points</span>.<br/>A <span style=\"color: #FFFFFF\">Quick Assist</span> is triggered when this skill hits an enemy.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating reaches Maximum, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to trigger:<br/>Unleash a powerful strike on enemies in a large area around the character, dealing massive <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Enemies hit with a heavy attack are inflicted with the <span style=\"color: #FFFFFF\">Sweet Scare</span> state.<br/>Upon activating this skill, other squad members gain <span style=\"color: #2BAD00\">25</span> Energy.<br/>Upon activating this skill, gain 2 <span style=\"color: #FFFFFF\">Sugar Points</span>.<br/>A <span style=\"color: #FFFFFF\">Quick Assist</span> is triggered when this skill hits an enemy.<br/>Character is invulnerable while using this skill.<!-- --></span>"
                ],
