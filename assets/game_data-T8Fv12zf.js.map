        "coreSkill": {
            "desc": [
                "<div class=\"flex flex-col gap-2.5 text-sm leading-4\"><!--[--><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Core Passive: Mini Destruction Partner<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->When ordering Drusilla or Anastella to attack, other squad members' PEN Ratio increases together with Rina's, by 25% of Rina's PEN Ratio + <span style=\"color: #2BAD00\">12%</span>, up to 30%. The effect ends when both Drusilla and Anastella return to Rina.<!-- --></span><!--]--><!-- --></p></div><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Additional Ability: Banquet of Perfection<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->When another character in your squad shares the same Attribute or Faction:<br/>Increases the duration of <span style=\"color: #2EB6FF\">Shock</span> inflicted on enemies by any character by 3s. When <span style=\"color: #2EB6FF\">Shocked</span> enemies are on the field, all squad members' <span style=\"color: #2EB6FF\">Electric DMG</span> increases by 10%.<!-- --></span><!--]--><!-- --></p></div><!--]--><!-- --></div>"
            ],
            "coreGrowthStat": {
                "23101": 48000,
                "12101": 25
            }
        }
    },
