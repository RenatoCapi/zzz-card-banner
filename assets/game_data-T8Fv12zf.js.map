        "skillKit": {
            "0": {
                "skillId": 0,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Tanuki Claws<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Unleashes up to 5 strikes ahead, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Unleashes up to 5 strikes ahead, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Tanuki Cloak<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Enter a defensive stance for up to 1.5 seconds. If hit during this time, parry the attack and inflict massive Daze against the attacking enemy.<br/>Successfully parrying an attack gains 1 <span style=\"color: #FFFFFF\">Sugar Points</span>.<br/>Character is invulnerable when successfully parrying.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Enter a defensive stance for up to 1.5 seconds. If hit during this time, parry the attack and inflict massive Daze against the attacking enemy.<br/>Successfully parrying an attack gains 1 <span style=\"color: #FFFFFF\">Sugar Points</span>.<br/>Character is invulnerable when successfully parrying.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Hard Candy Shot<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Yuzuha has <span style=\"color: #FFFFFF\">Sugar Points</span>, landing a hit with other active characters' attacks will have Yuzuha continuously twirl her umbrella and attack centered around the target before launching a powerful shell, dealing <span style=\"color: #F0D12B\">Physical DMG</span>. When this attack lands a heavy attack, Yuzuha consumes 1 <span style=\"color: #FFFFFF\">Sugar Point</span>.<br/><span style=\"color: #FFFFFF\">Basic Attack: Hard Candy Shot</span> is considered an <span style=\"color: #FFFFFF\">Aftershock</span>.<br/><span style=\"color: #FFFFFF\">Basic Attack: Hard Candy Shot</span> can be triggered once every 8s.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Yuzuha has <span style=\"color: #FFFFFF\">Sugar Points</span>, landing a hit with other active characters' attacks will have Yuzuha continuously twirl her umbrella and attack centered around the target before launching a powerful shell, dealing <span style=\"color: #F0D12B\">Physical DMG</span>. When this attack lands a heavy attack, Yuzuha consumes 1 <span style=\"color: #FFFFFF\">Sugar Point</span>.<br/><span style=\"color: #FFFFFF\">Basic Attack: Hard Candy Shot</span> is considered an <span style=\"color: #FFFFFF\">Aftershock</span>.<br/><span style=\"color: #FFFFFF\">Basic Attack: Hard Candy Shot</span> can be triggered once every 8s.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Sugarburst Sparkles<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Enemies under the effect of <span style=\"color: #FFFFFF\">Sweet Scare</span> will be attacked by a <span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles</span> once every 1s.<br/><span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles</span> initially deals <span style=\"color: #F0D12B\">Physical DMG</span>.<br/><span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles</span> does not contribute its accumulated Attribute Anomaly Buildup toward Anomaly DMG calculation.<br/><span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles</span> Anomaly Buildup Rate increases by <span style=\"color: #2BAD00\">25%</span>.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Enemies under the effect of <span style=\"color: #FFFFFF\">Sweet Scare</span> will be attacked by a <span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles</span> once every 1s.<br/><span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles</span> initially deals <span style=\"color: #F0D12B\">Physical DMG</span>.<br/><span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles</span> does not contribute its accumulated Attribute Anomaly Buildup toward Anomaly DMG calculation.<br/><span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles</span> Anomaly Buildup Rate increases by <span style=\"color: #2BAD00\">25%</span>.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Sugarburst Sparkles - Max<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Enemies affected by <span style=\"color: #FFFFFF\">Sweet Scare</span> will be attacked by a <span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles - Max</span> when hit with a heavy attack from <span style=\"color: #FFFFFF\">Basic Attack: Hard Candy Shot</span> or <span style=\"color: #FFFFFF\">Assist Follow-Up: Stuffed Hard Candy Shot</span>.<br/><span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles - Max</span> initially deals <span style=\"color: #F0D12B\">Physical DMG</span>.<br/><span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles - Max</span> does not contribute its accumulated Attribute Anomaly Buildup toward Anomaly DMG calculation.<br/><span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles - Max</span> Anomaly Buildup Rate increases by <span style=\"color: #2BAD00\">25%</span>.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Enemies affected by <span style=\"color: #FFFFFF\">Sweet Scare</span> will be attacked by a <span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles - Max</span> when hit with a heavy attack from <span style=\"color: #FFFFFF\">Basic Attack: Hard Candy Shot</span> or <span style=\"color: #FFFFFF\">Assist Follow-Up: Stuffed Hard Candy Shot</span>.<br/><span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles - Max</span> initially deals <span style=\"color: #F0D12B\">Physical DMG</span>.<br/><span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles - Max</span> does not contribute its accumulated Attribute Anomaly Buildup toward Anomaly DMG calculation.<br/><span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles - Max</span> Anomaly Buildup Rate increases by <span style=\"color: #2BAD00\">25%</span>.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Tanuki Helper<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Yuzuha is off-field, tanuki Kama assists the active character in attacking enemies, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>When Yuzuha performs <span style=\"color: #FFFFFF\">Basic Attack: Tanuki Cloak</span>, tanuki Kama joins her in attacking the enemy, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Tanuki Kama inherits Yuzuha's initial ATK.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Yuzuha is off-field, tanuki Kama assists the active character in attacking enemies, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>When Yuzuha performs <span style=\"color: #FFFFFF\">Basic Attack: Tanuki Cloak</span>, tanuki Kama joins her in attacking the enemy, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Tanuki Kama inherits Yuzuha's initial ATK.<!-- --></span>"
                ],
