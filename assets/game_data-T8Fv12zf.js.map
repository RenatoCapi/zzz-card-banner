                "growth": 66441,
                "asc": 33
            }
        },
        "staticStats": {
            "12201": 83,
            "20101": 50000,
            "21101": 500000,
            "31401": 94,
            "31201": 93,
            "23101": 0,
            "30501": 12000
        },
        "skillKit": {
            "0": {
                "skillId": 0,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Swiftedge<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Launches up to four forward slashes, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Can be chained into <span style=\"color: #FFFFFF\">Dash Attack: Phantasm Dash</span> after the 4th hit.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Launches up to four forward slashes, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Can be chained into <span style=\"color: #FFFFFF\">Dash Attack: Phantasm Dash</span> after the 4th hit.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Cloudstream Sword Will<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Launches a flurry of blade shockwaves, dealing <span style=\"color: #F0D12B\">Physical DMG</span>. Hold to extend the attack.<br/>Anti-Interrupt Level is increased during this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Launches a flurry of blade shockwaves, dealing <span style=\"color: #F0D12B\">Physical DMG</span>. Hold to extend the attack.<br/>Anti-Interrupt Level is increased during this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Enlightened Mind - Splitting Currents<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->While in the <span style=\"color: #FFFFFF\">Enlightened Mind</span> state and on the ground, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Performs up to three forward slashes, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>If struck by an enemy attack during the 3rd hit, triggers a block, negating that instance of DMG.<br/>If she possesses <span style=\"color: #FFFFFF\">Qingming Sword Force</span>, the 3rd hit is replaced with <span style=\"color: #FFFFFF\">Basic Attack: Enlightened Mind - Skyward Ascent</span>.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->While in the <span style=\"color: #FFFFFF\">Enlightened Mind</span> state and on the ground, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Performs up to three forward slashes, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>If struck by an enemy attack during the 3rd hit, triggers a block, negating that instance of DMG.<br/>If she possesses <span style=\"color: #FFFFFF\">Qingming Sword Force</span>, the 3rd hit is replaced with <span style=\"color: #FFFFFF\">Basic Attack: Enlightened Mind - Skyward Ascent</span>.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Enlightened Mind - Skyward Ascent<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->While in the <span style=\"color: #FFFFFF\">Enlightened Mind</span> state and with <span style=\"color: #FFFFFF\">Qingming Sword Force</span>, after the 2nd hit of <span style=\"color: #FFFFFF\">Basic Attack: Enlightened Mind - Splitting Currents</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Launches a swift rising attack, dealing <span style=\"color: #F0D12B\">Physical DMG</span> and entering an airborne state.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->While in the <span style=\"color: #FFFFFF\">Enlightened Mind</span> state and with <span style=\"color: #FFFFFF\">Qingming Sword Force</span>, after the 2nd hit of <span style=\"color: #FFFFFF\">Basic Attack: Enlightened Mind - Splitting Currents</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Launches a swift rising attack, dealing <span style=\"color: #F0D12B\">Physical DMG</span> and entering an airborne state.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Enlightened Mind - Sunderlight Maximum<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->After activating <span style=\"color: #FFFFFF\">Basic Attack: Enlightened Mind - Sunderlight Annihilation</span>, and with <span style=\"color: #FFFFFF\">Qingming Sword Force</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Launches a wide sweeping slash forward, dealing massive <span style=\"color: #F0D12B\">Physical DMG</span>. On hit, 1 point of <span style=\"color: #FFFFFF\">Qingming Sword Force</span> is consumed.<br/>If struck by an enemy during the skill, triggers a block, negating that instance of DMG and increasing the skill's Interrupt Level.<br/>After using this skill and with <span style=\"color: #FFFFFF\">Qingming Sword Force</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to consume 1 point of <span style=\"color: #FFFFFF\">Qingming Sword Force</span> and launch a hit of <span style=\"color: #FFFFFF\">EX Special Attack: Enlightened Mind - Soaring Light</span>. This skill is automatically followed up with <span style=\"color: #FFFFFF\">Basic Attack: Enlightened Mind - Skyward Ascent</span>, and Ye Shunguang enters an airborne state.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->After activating <span style=\"color: #FFFFFF\">Basic Attack: Enlightened Mind - Sunderlight Annihilation</span>, and with <span style=\"color: #FFFFFF\">Qingming Sword Force</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Launches a wide sweeping slash forward, dealing massive <span style=\"color: #F0D12B\">Physical DMG</span>. On hit, 1 point of <span style=\"color: #FFFFFF\">Qingming Sword Force</span> is consumed.<br/>If struck by an enemy during the skill, triggers a block, negating that instance of DMG and increasing the skill's Interrupt Level.<br/>After using this skill and with <span style=\"color: #FFFFFF\">Qingming Sword Force</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to consume 1 point of <span style=\"color: #FFFFFF\">Qingming Sword Force</span> and launch a hit of <span style=\"color: #FFFFFF\">EX Special Attack: Enlightened Mind - Soaring Light</span>. This skill is automatically followed up with <span style=\"color: #FFFFFF\">Basic Attack: Enlightened Mind - Skyward Ascent</span>, and Ye Shunguang enters an airborne state.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Enlightened Mind - Sunderlight<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->In the <span style=\"color: #FFFFFF\">Enlightened Mind</span> state, and while airborne, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Launches up to two downward slashes in front, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Ye Shunguang will not exit the <span style=\"color: #FFFFFF\">Enlightened Mind</span> state during this skill.<br/>Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> or <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/5161803192951478865_250_13063804.webp\"/> to follow up with <span style=\"color: #FFFFFF\">Basic Attack: Enlightened Mind - Sunderlight Annihilation</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->In the <span style=\"color: #FFFFFF\">Enlightened Mind</span> state, and while airborne, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Launches up to two downward slashes in front, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Ye Shunguang will not exit the <span style=\"color: #FFFFFF\">Enlightened Mind</span> state during this skill.<br/>Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> or <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/5161803192951478865_250_13063804.webp\"/> to follow up with <span style=\"color: #FFFFFF\">Basic Attack: Enlightened Mind - Sunderlight Annihilation</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Enlightened Mind - Sunderlight Annihilation<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->After the 2nd hit of <span style=\"color: #FFFFFF\">Basic Attack: Enlightened Mind - Sunderlight</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Performs a falling attack in front, entering a grounded state, and dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>When launching this skill with 2 or more points of <span style=\"color: #FFFFFF\">Qingming Sword Force</span>, Ye Shunguang will perform a downward falling strike across a large area in front instead, dealing massive <span style=\"color: #F0D12B\">Physical DMG</span>. On hit, 2 points of <span style=\"color: #FFFFFF\">Qingming Sword Force</span> are consumed, granting the <span style=\"color: #FFFFFF\">Culmination</span> effect. After using this skill, if Ye Shunguang possesses <span style=\"color: #FFFFFF\">Qingming Sword Force</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to consume 1 point of <span style=\"color: #FFFFFF\">Qingming Sword Force</span> and launch a hit of <span style=\"color: #FFFFFF\">EX Special Attack: Enlightened Mind - Soaring Light</span>, which can be quickly followed up with <span style=\"color: #FFFFFF\">Basic Attack: Enlightened Mind - Sunderlight Maximum</span>.<br/>Ye Shunguang will not exit the <span style=\"color: #FFFFFF\">Enlightened Mind</span> state during this skill.<br/>During this skill, if attacked by enemies, triggers a block, negating that instance of DMG.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->After the 2nd hit of <span style=\"color: #FFFFFF\">Basic Attack: Enlightened Mind - Sunderlight</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Performs a falling attack in front, entering a grounded state, and dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>When launching this skill with 2 or more points of <span style=\"color: #FFFFFF\">Qingming Sword Force</span>, Ye Shunguang will perform a downward falling strike across a large area in front instead, dealing massive <span style=\"color: #F0D12B\">Physical DMG</span>. On hit, 2 points of <span style=\"color: #FFFFFF\">Qingming Sword Force</span> are consumed, granting the <span style=\"color: #FFFFFF\">Culmination</span> effect. After using this skill, if Ye Shunguang possesses <span style=\"color: #FFFFFF\">Qingming Sword Force</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to consume 1 point of <span style=\"color: #FFFFFF\">Qingming Sword Force</span> and launch a hit of <span style=\"color: #FFFFFF\">EX Special Attack: Enlightened Mind - Soaring Light</span>, which can be quickly followed up with <span style=\"color: #FFFFFF\">Basic Attack: Enlightened Mind - Sunderlight Maximum</span>.<br/>Ye Shunguang will not exit the <span style=\"color: #FFFFFF\">Enlightened Mind</span> state during this skill.<br/>During this skill, if attacked by enemies, triggers a block, negating that instance of DMG.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Culmination<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->During <span style=\"color: #FFFFFF\">EX Special Attack: Enlightened Mind - Soaring Light</span>, each time <span style=\"color: #FFFFFF\">Qingming Sword Force</span> is consumed while <span style=\"color: #FFFFFF\">Culmination</span> is active, the <span style=\"color: #FFFFFF\">Qingming Sword Force</span> cost is replaced by consuming <span style=\"color: #FFFFFF\">Culmination</span> instead. This effect does not stack, and lasts until the current <span style=\"color: #FFFFFF\">Enlightened Mind</span> ends.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->During <span style=\"color: #FFFFFF\">EX Special Attack: Enlightened Mind - Soaring Light</span>, each time <span style=\"color: #FFFFFF\">Qingming Sword Force</span> is consumed while <span style=\"color: #FFFFFF\">Culmination</span> is active, the <span style=\"color: #FFFFFF\">Qingming Sword Force</span> cost is replaced by consuming <span style=\"color: #FFFFFF\">Culmination</span> instead. This effect does not stack, and lasts until the current <span style=\"color: #FFFFFF\">Enlightened Mind</span> ends.<!-- --></span>"
                ],
