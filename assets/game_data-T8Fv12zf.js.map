            "0": {
                "skillId": 0,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Rampaging Slash<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Unleashes up to 6 slashes ahead, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Unleashes up to 6 slashes ahead, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Dead End<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When there are sufficient <span style=\"color: #FFFFFF\">Assist Points</span>, hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Consume 1 <span style=\"color: #FFFFFF\">Assist Point</span> to toss the shield and attack nearby enemies in all directions, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When there are sufficient <span style=\"color: #FFFFFF\">Assist Points</span>, hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Consume 1 <span style=\"color: #FFFFFF\">Assist Point</span> to toss the shield and attack nearby enemies in all directions, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>"
