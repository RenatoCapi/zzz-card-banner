            "2": {
                "skillId": 2,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Dodge: Lightstream<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/5161803192951478865_250_13063804.webp\"/> to activate:<br/>A quick dash dodge.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/5161803192951478865_250_13063804.webp\"/> to activate:<br/>A quick dash dodge.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Dash Attack: Silver Thorned Melody<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> during a dodge to activate:<br/>Launches a forward thrust at enemies in front, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> during a dodge to activate:<br/>Launches a forward thrust at enemies in front, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Dodge Counter: Wingblade Reverb<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> during a <span style=\"color: #FFFFFF\">Perfect Dodge</span> to activate:<br/>Launches an attack on enemies ahead, dealing <span style=\"color: #F0D12B\">Physical DMG</span> and <span style=\"color: #FE437E\">Ether DMG</span>.<br/>Character is invulnerable while using this skill.<br/>After activating the skill, enter the <span style=\"color: #FFFFFF\">Noblewoman</span> state.<br/>When there are <span style=\"color: #FFFFFF\">Flight Feathers</span> available, hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> during skill activation to enter the <span style=\"color: #FFFFFF\">Fluttering Frock</span> state.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> during a <span style=\"color: #FFFFFF\">Perfect Dodge</span> to activate:<br/>Launches an attack on enemies ahead, dealing <span style=\"color: #F0D12B\">Physical DMG</span> and <span style=\"color: #FE437E\">Ether DMG</span>.<br/>Character is invulnerable while using this skill.<br/>After activating the skill, enter the <span style=\"color: #FFFFFF\">Noblewoman</span> state.<br/>When there are <span style=\"color: #FFFFFF\">Flight Feathers</span> available, hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> during skill activation to enter the <span style=\"color: #FFFFFF\">Fluttering Frock</span> state.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Dodge: Dainty Steps<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When in the <span style=\"color: #FFFFFF\">Noblewoman</span> state and about to be attacked, an automatic dodge will trigger, during which the character will be Invulnerable, but a <span style=\"color: #FFFFFF\">Perfect Dodge</span> will not be triggered.<br/>This can trigger once each time the <span style=\"color: #FFFFFF\">Noblewoman</span> state is entered.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When in the <span style=\"color: #FFFFFF\">Noblewoman</span> state and about to be attacked, an automatic dodge will trigger, during which the character will be Invulnerable, but a <span style=\"color: #FFFFFF\">Perfect Dodge</span> will not be triggered.<br/>This can trigger once each time the <span style=\"color: #FFFFFF\">Noblewoman</span> state is entered.<!-- --></span>"
                ],
