            "1": {
                "skillId": 1,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Special Attack: Sugarcoated Bullet<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to activate:<br/>Unleashes a ranged strike against enemies in front, dealing <span style=\"color: #FE437E\">Ether DMG</span>.<br/>Anti-Interrupt level is increased while using this skill.<br/>Automatically reloads after the attack to enhance <span style=\"color: #FFFFFF\">Basic Attack</span> and <span style=\"color: #FFFFFF\">Dash Attack</span> up to 8 times.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to activate:<br/>Unleashes a ranged strike against enemies in front, dealing <span style=\"color: #FE437E\">Ether DMG</span>.<br/>Anti-Interrupt level is increased while using this skill.<br/>Automatically reloads after the attack to enhance <span style=\"color: #FFFFFF\">Basic Attack</span> and <span style=\"color: #FFFFFF\">Dash Attack</span> up to 8 times.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->EX Special Attack: Stuffed Sugarcoated Bullet<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->With enough Energy, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to activate:<br/>A powerful ranged strike, generating an energy field that pulls enemies towards its center to deal <span style=\"color: #FE437E\">Ether DMG</span>.<br/>Hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> down to charge up this attack, during which a small energy field is generated at the muzzle as Energy is consumed, dealing bonus DMG to enemies nearby.<br/>Character is invulnerable while using this skill.<br/>A <span style=\"color: #FFFFFF\">Quick Assist</span> is triggered when this skill hits an enemy.<br/>Automatically reloads after the attack to enhance <span style=\"color: #FFFFFF\">Basic Attack</span> and <span style=\"color: #FFFFFF\">Dash Attack</span> up to 8 times.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->With enough Energy, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to activate:<br/>A powerful ranged strike, generating an energy field that pulls enemies towards its center to deal <span style=\"color: #FE437E\">Ether DMG</span>.<br/>Hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> down to charge up this attack, during which a small energy field is generated at the muzzle as Energy is consumed, dealing bonus DMG to enemies nearby.<br/>Character is invulnerable while using this skill.<br/>A <span style=\"color: #FFFFFF\">Quick Assist</span> is triggered when this skill hits an enemy.<br/>Automatically reloads after the attack to enhance <span style=\"color: #FFFFFF\">Basic Attack</span> and <span style=\"color: #FFFFFF\">Dash Attack</span> up to 8 times.<!-- --></span>"
                ],
