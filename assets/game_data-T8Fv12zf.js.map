        "coreSkill": {
            "desc": [
                "<div class=\"flex flex-col gap-2.5 text-sm leading-4\"><!--[--><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Core Passive: Crimson Mane Guard<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->When Lucy uses her <span style=\"color: #FFFFFF\">Special Attack</span> or <span style=\"color: #FFFFFF\">EX Special Attack</span>, a guard boar will join the battle and call in two other guard boars. The guard boars inherit Lucy's ATK, Impact, and Anomaly Proficiency. The <span style=\"color: #FFFFFF\">Cheer On!</span> buff for the guard boars is increased to <span style=\"color: #2BAD00\">200%</span> of the original effect, and their attack frequency is increased.<!-- --></span><!--]--><!-- --></p></div><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Additional Ability: Batter Up!<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->When another character in your squad shares the same Attribute or Faction or is a <span style=\"color: #FFFFFF\">Rupture</span> character:<br/>The guard boars inherit Lucy's CRIT Rate and CRIT DMG.<!-- --></span><!--]--><!-- --></p></div><!--]--><!-- --></div>"
            ],
            "coreGrowthStat": {
                "30501": 1200,
                "12101": 25
            }
        }
    },
