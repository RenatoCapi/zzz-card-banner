        "skillKit": {
            "0": {
                "skillId": 0,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Cirrus Strike<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Perform up to five attacks forward, dealing <span style=\"color: #FE437E\">Auric\u00a0Ink DMG</span>.<br/>This skill's Anti-Interrupt Level increases during the 3rd and 4th hit.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Perform up to five attacks forward, dealing <span style=\"color: #FE437E\">Auric\u00a0Ink DMG</span>.<br/>This skill's Anti-Interrupt Level increases during the 3rd and 4th hit.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Ink\u2010Veil Cloud Coalescence<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/5161803192951478865_250_13063804.webp\"/> to activate:<br/>Deploy a Grand Tai Chi Formation, dealing <span style=\"color: #FE437E\">Auric\u00a0Ink DMG</span>.<br/>When the skill ends, automatically launch the 5th hit of Basic Attack: Cirrus Strike.<br/>Anti-Interrupt level is increased while using this skill, and DMG received is reduced by 40%.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/5161803192951478865_250_13063804.webp\"/> to activate:<br/>Deploy a Grand Tai Chi Formation, dealing <span style=\"color: #FE437E\">Auric\u00a0Ink DMG</span>.<br/>When the skill ends, automatically launch the 5th hit of Basic Attack: Cirrus Strike.<br/>Anti-Interrupt level is increased while using this skill, and DMG received is reduced by 40%.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Auric Array<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->While possessing an Auric Ink Point: tap <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> during Dodge: Nimbus Step, or hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/5161803192951478865_250_13063804.webp\"/> to activate:<br/>Deploy an array, continuously dealing <span style=\"color: #FE437E\">Auric Ink DMG</span>.<br/>When the skill ends, it automatically triggers Basic Attack: Qingming Eruption.<br/>While channeling, continuously recover Adrenaline, recovering 7/s, for up to 3s.<br/>Character is invulnerable while using this skill, and enters the Vital View state.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->While possessing an Auric Ink Point: tap <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> during Dodge: Nimbus Step, or hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/5161803192951478865_250_13063804.webp\"/> to activate:<br/>Deploy an array, continuously dealing <span style=\"color: #FE437E\">Auric Ink DMG</span>.<br/>When the skill ends, it automatically triggers Basic Attack: Qingming Eruption.<br/>While channeling, continuously recover Adrenaline, recovering 7/s, for up to 3s.<br/>Character is invulnerable while using this skill, and enters the Vital View state.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Qingming Eruption<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Automatically activates when Basic Attack: Auric Array reaches the max duration:<br/>Spreads her wings to launch an explosive attack, dealing massive <span style=\"color: #FE437E\">Auric\u00a0Ink DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Automatically activates when Basic Attack: Auric Array reaches the max duration:<br/>Spreads her wings to launch an explosive attack, dealing massive <span style=\"color: #FE437E\">Auric\u00a0Ink DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>"
                ],
