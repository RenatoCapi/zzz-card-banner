            "6": {
                "skillId": 6,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Quick Assist: Dessert Time<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When the active character is launched, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2454651411643363052_250_13063804.webp\"/> to activate:<br/>Strike enemies in front, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When the active character is launched, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2454651411643363052_250_13063804.webp\"/> to activate:<br/>Strike enemies in front, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Defensive Assist: Replenish Your Fun<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When the on-field character is about to be attacked, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2454651411643363052_250_13063804.webp\"/> to activate:<br/>Parries the enemy's attack, dealing massive Daze.<br/>Upon a successful parry, gain 1 <span style=\"color: #FFFFFF\">Sugar Points</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When the on-field character is about to be attacked, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2454651411643363052_250_13063804.webp\"/> to activate:<br/>Parries the enemy's attack, dealing massive Daze.<br/>Upon a successful parry, gain 1 <span style=\"color: #FFFFFF\">Sugar Points</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Assist Follow-Up: We Have Cookies<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->After triggering a <span style=\"color: #FFFFFF\">Defensive Assist</span> or successfully parrying an enemy attack with <span style=\"color: #FFFFFF\">Basic Attack: Tanuki Cloak</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Strike enemies in front, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->After triggering a <span style=\"color: #FFFFFF\">Defensive Assist</span> or successfully parrying an enemy attack with <span style=\"color: #FFFFFF\">Basic Attack: Tanuki Cloak</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Strike enemies in front, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Assist Follow-Up: Stuffed Hard Candy Shot<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->After triggering a <span style=\"color: #FFFFFF\">Defensive Assist</span> or successfully parrying an enemy attack with <span style=\"color: #FFFFFF\">Basic Attack: Tanuki Cloak</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> at the right moment to activate:<br/>Following a continuous spinning umbrella attack, fire a powerful projectile that deals <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->After triggering a <span style=\"color: #FFFFFF\">Defensive Assist</span> or successfully parrying an enemy attack with <span style=\"color: #FFFFFF\">Basic Attack: Tanuki Cloak</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> at the right moment to activate:<br/>Following a continuous spinning umbrella attack, fire a powerful projectile that deals <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>"
                ],
