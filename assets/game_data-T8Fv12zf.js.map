        "skillKit": {
            "0": {
                "skillId": 0,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Tiger Seven Forms - Flaming Claw<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Slash forward up to four times, dealing <span style=\"color: #F0D12B\">Physical DMG</span> and <span style=\"color: #FF5521\">Fire DMG</span>.<br/>During the 3rd hit, repeatedly press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to maintain the combo and keep striking the enemy.<br/>During the 3rd hit, hold or pause before pressing <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to chain into the 4th hit.<br/>During the 3rd hit, Anti-Interrupt Level is increased, and DMG received is reduced by 40%.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Slash forward up to four times, dealing <span style=\"color: #F0D12B\">Physical DMG</span> and <span style=\"color: #FF5521\">Fire DMG</span>.<br/>During the 3rd hit, repeatedly press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to maintain the combo and keep striking the enemy.<br/>During the 3rd hit, hold or pause before pressing <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to chain into the 4th hit.<br/>During the 3rd hit, Anti-Interrupt Level is increased, and DMG received is reduced by 40%.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Hu Wei<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->During combat, Hu Wei will automatically attack enemies, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>Upon hitting an enemy, gain 20 points of <span style=\"color: #FFFFFF\">Might</span>, triggering up to once per use of a skill. The maximum for <span style=\"color: #FFFFFF\">Might</span> is 200.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->During combat, Hu Wei will automatically attack enemies, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>Upon hitting an enemy, gain 20 points of <span style=\"color: #FFFFFF\">Might</span>, triggering up to once per use of a skill. The maximum for <span style=\"color: #FFFFFF\">Might</span> is 200.<!-- --></span>"
                ],
