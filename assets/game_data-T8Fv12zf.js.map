            "1": {
                "skillId": 1,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Special Attack: Withered in Frost<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to activate:<br/>Throw a steel wheel that traces a curved path, dealing <span style=\"color: #2EB6FF\">Electric DMG</span>.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to activate:<br/>Throw a steel wheel that traces a curved path, dealing <span style=\"color: #2EB6FF\">Electric DMG</span>.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->EX Special Attack: Raining Iron Petals<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->With enough Energy, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to activate:<br/>Enter flight mode, where Seed can move in four directions, and unleash a continuous barrage of missiles, dealing massive <span style=\"color: #2EB6FF\">Electric DMG</span>.<br/>Hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to extend the barrage duration while continuously consuming Energy.<br/>During flight, release <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to trigger <span style=\"color: #FFFFFF\">EX Special Attack: Raining Iron Petals - Away</span>.<br/>Upon consuming 60 Energy points in one flight, automatically trigger <span style=\"color: #FFFFFF\">Basic Attack: Falling Petals - Slaughter</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->With enough Energy, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to activate:<br/>Enter flight mode, where Seed can move in four directions, and unleash a continuous barrage of missiles, dealing massive <span style=\"color: #2EB6FF\">Electric DMG</span>.<br/>Hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to extend the barrage duration while continuously consuming Energy.<br/>During flight, release <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to trigger <span style=\"color: #FFFFFF\">EX Special Attack: Raining Iron Petals - Away</span>.<br/>Upon consuming 60 Energy points in one flight, automatically trigger <span style=\"color: #FFFFFF\">Basic Attack: Falling Petals - Slaughter</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->EX Special Attack: Raining Iron Petals - Away<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->During <span style=\"color: #FFFFFF\">EX Special Attack: Raining Iron Petals</span>, release <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to activate:<br/>Unleash rapid cannon fire, dealing <span style=\"color: #2EB6FF\">Electric DMG</span>.<br/>Does not accumulate <span style=\"color: #FFFFFF\">Steel Charge</span> on hit.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->During <span style=\"color: #FFFFFF\">EX Special Attack: Raining Iron Petals</span>, release <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to activate:<br/>Unleash rapid cannon fire, dealing <span style=\"color: #2EB6FF\">Electric DMG</span>.<br/>Does not accumulate <span style=\"color: #FFFFFF\">Steel Charge</span> on hit.<br/>Character is invulnerable while using this skill.<!-- --></span>"
                ],
