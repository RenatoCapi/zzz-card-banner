        "coreSkill": {
            "desc": [
                "<div class=\"flex flex-col gap-2.5 text-sm leading-4\"><!--[--><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Core Passive: Power Charge<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->When Piper's <span style=\"color: #FFFFFF\">EX Special Attack: Engine Spin</span> or <span style=\"color: #FFFFFF\">Ultimate</span> hits an enemy, she gains 1 stack of <span style=\"color: #FFFFFF\">Power</span>, up to a maximum of 20 stacks, lasting for 12s. Repeated triggers reset the duration. For every stack of <span style=\"color: #FFFFFF\">Power</span>, Piper's <span style=\"color: #F0D12B\">Physical Anomaly Buildup Rate</span> increases by <span style=\"color: #2BAD00\">4%</span>.<!-- --></span><!--]--><!-- --></p></div><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Additional Ability: Synced Acceleration<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->When another character in your squad shares the same Attribute or Faction:<br/>When Piper has 20 or more stacks of <span style=\"color: #FFFFFF\">Power</span>, all squad members' DMG is increased by 18%.<!-- --></span><!--]--><!-- --></p></div><!--]--><!-- --></div>"
            ],
            "coreGrowthStat": {
                "30501": 1200,
                "12101": 25
            }
        }
    },
