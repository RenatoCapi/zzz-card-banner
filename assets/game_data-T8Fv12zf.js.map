            "1": {
                "skillId": 1,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Special Attack: Tire Spin<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to activate:<br/>Piper spins and launches a sweeping slash around her, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to extend the skill duration, unleashing increasingly powerful spinning slashes and increasing the charge level of the skill up to 2 times.<br/>If the skill is used after the first 3 hits of a <span style=\"color: #FFFFFF\">Basic Attack</span>, <span style=\"color: #FFFFFF\">Dash Attack</span>, or <span style=\"color: #FFFFFF\">Dodge Counter</span>, you can quickly activate <span style=\"color: #FFFFFF\">Special Attack: Tire Spin</span> of an increased charge level.<br/>During the skill activation, Anti-Interrupt level increases, and DMG taken is reduced by 40%.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to activate:<br/>Piper spins and launches a sweeping slash around her, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to extend the skill duration, unleashing increasingly powerful spinning slashes and increasing the charge level of the skill up to 2 times.<br/>If the skill is used after the first 3 hits of a <span style=\"color: #FFFFFF\">Basic Attack</span>, <span style=\"color: #FFFFFF\">Dash Attack</span>, or <span style=\"color: #FFFFFF\">Dodge Counter</span>, you can quickly activate <span style=\"color: #FFFFFF\">Special Attack: Tire Spin</span> of an increased charge level.<br/>During the skill activation, Anti-Interrupt level increases, and DMG taken is reduced by 40%.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Special Attack: One Trillion Tons<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->While <span style=\"color: #FFFFFF\">Special Attack: Tire Spin</span> is active, release <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to trigger a downward smash attack based on the charge level of <span style=\"color: #FFFFFF\">Special Attack: Tire Spin</span>, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->While <span style=\"color: #FFFFFF\">Special Attack: Tire Spin</span> is active, release <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to trigger a downward smash attack based on the charge level of <span style=\"color: #FFFFFF\">Special Attack: Tire Spin</span>, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->EX Special Attack: Engine Spin<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->With enough Energy, continue holding <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> after <span style=\"color: #FFFFFF\">Special Attack: Tire Spin</span> reaches maximum charge level to activate:<br/>Rapidly spins, unleashing powerful spinning slashes around her and dealing massive <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>This skill consumes Energy continuously for up to 3s.<br/>During the skill activation, Anti-Interrupt level increases, and DMG taken is reduced by 40%.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->With enough Energy, continue holding <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> after <span style=\"color: #FFFFFF\">Special Attack: Tire Spin</span> reaches maximum charge level to activate:<br/>Rapidly spins, unleashing powerful spinning slashes around her and dealing massive <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>This skill consumes Energy continuously for up to 3s.<br/>During the skill activation, Anti-Interrupt level increases, and DMG taken is reduced by 40%.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->EX Special Attack:\u00a0Really Heavy<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->During <span style=\"color: #FFFFFF\">EX Special Attack: Engine Spin</span>, release <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to activate:<br/>Piper unleashes a downward smash attack, dealing massive <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>If the duration of <span style=\"color: #FFFFFF\">EX Special Attack: Engine Spin</span> reaches its limit or Energy drops to 20, <span style=\"color: #FFFFFF\">EX Special Attack: Really Heavy</span> will automatically activate.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->During <span style=\"color: #FFFFFF\">EX Special Attack: Engine Spin</span>, release <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to activate:<br/>Piper unleashes a downward smash attack, dealing massive <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>If the duration of <span style=\"color: #FFFFFF\">EX Special Attack: Engine Spin</span> reaches its limit or Energy drops to 20, <span style=\"color: #FFFFFF\">EX Special Attack: Really Heavy</span> will automatically activate.<br/>Character is invulnerable while using this skill.<!-- --></span>"
                ],
