        "coreSkill": {
            "desc": [
                "<div class=\"flex flex-col gap-2.5 text-sm leading-4\"><!--[--><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Core Passive: Heatwave<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->When triggering <span style=\"color: #FFFFFF\">Fire Suppression</span> during a <span style=\"color: #FFFFFF\">Basic Attack</span> or <span style=\"color: #FFFFFF\">Dash Attack</span>, increase that attack's DMG by <span style=\"color: #2BAD00\">70%</span>.<!-- --></span><!--]--><!-- --></p></div><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Additional Ability: Fields of Fire<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->When another character in your squad shares the same Attribute or Faction:<br/>Soldier 11 deals 10% more <span style=\"color: #FF5521\">Fire DMG</span>. When attacking Stunned enemies, this effect is further enhanced by an additional 22.5%.<!-- --></span><!--]--><!-- --></p></div><!--]--><!-- --></div>"
            ],
            "coreGrowthStat": {
                "20101": 48000,
                "12101": 25
            }
        }
