        "coreSkill": {
            "desc": [
                "<div class=\"flex flex-col gap-2.5 text-sm leading-4\"><!--[--><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Core Passive: Fluctuating Voltage<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->Launch a <span style=\"color: #FFFFFF\">Basic Attack: Thunderbolt</span>, <span style=\"color: #FFFFFF\">Special Attack</span>, or <span style=\"color: #FFFFFF\">EX Special Attack</span> after the 3rd hit of Anby's <span style=\"color: #FFFFFF\">Basic Attack</span> for an extra <span style=\"color: #2BAD00\">64%</span> Daze.<!-- --></span><!--]--><!-- --></p></div><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Additional Ability: Parallel Connection<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->When another character in your squad shares the same Attribute or Faction:<br/>When Anby's <span style=\"color: #FFFFFF\">Dodge Counter</span> hits an enemy, she gains an extra 7.2 Energy. This effect can trigger once every 5s.<!-- --></span><!--]--><!-- --></p></div><!--]--><!-- --></div>"
