            "6": {
                "skillId": 6,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Quick Assist: Batholith<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When the active character is launched, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2454651411643363052_250_13063804.webp\"/> to activate:<br/>Executes a series of attacks against enemies in front, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When the active character is launched, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2454651411643363052_250_13063804.webp\"/> to activate:<br/>Executes a series of attacks against enemies in front, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Defensive Assist: Iron Bastion<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When the on-field character is about to be attacked, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2454651411643363052_250_13063804.webp\"/> to activate:<br/>Parries the enemy's attack, dealing massive Daze.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When the on-field character is about to be attacked, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2454651411643363052_250_13063804.webp\"/> to activate:<br/>Parries the enemy's attack, dealing massive Daze.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Assist Follow-Up: Lofty Ascent<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> after a <span style=\"color: #FFFFFF\">Defensive Assist</span> to activate:<br/>Quickly dash forward and attack, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> after a <span style=\"color: #FFFFFF\">Defensive Assist</span> to activate:<br/>Quickly dash forward and attack, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Assist Follow-Up: Pierce Heavens<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->After successfully parrying an enemy attack with <span style=\"color: #FFFFFF\">Dodge: Immovable Mountain</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Quickly dash forward and attack, dealing <span style=\"color: #FF5521\">Fire DMG</span><br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->After successfully parrying an enemy attack with <span style=\"color: #FFFFFF\">Dodge: Immovable Mountain</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Quickly dash forward and attack, dealing <span style=\"color: #FF5521\">Fire DMG</span><br/>Character is invulnerable while using this skill.<!-- --></span>"
                ],
