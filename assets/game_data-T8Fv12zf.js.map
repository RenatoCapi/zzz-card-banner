            "2": {
                "skillId": 2,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Dodge: Arc Step<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/5161803192951478865_250_13063804.webp\"/> to activate:<br/>A quick dash dodge.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/5161803192951478865_250_13063804.webp\"/> to activate:<br/>A quick dash dodge.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Dash Attack: Piercing Ambush<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> during a dodge to activate:<br/>Deliver a kick to the enemy in front, causing <span style=\"color: #F0D12B\">Physical DMG</span>.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> during a dodge to activate:<br/>Deliver a kick to the enemy in front, causing <span style=\"color: #F0D12B\">Physical DMG</span>.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Dodge Counter: Strangling Reversal<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> during a <span style=\"color: #FFFFFF\">Perfect Dodge</span> to activate:<br/>Use <span style=\"color: #FFFFFF\">Lunalux Garrote</span> to slash surrounding enemies, dealing <span style=\"color: #FF5521\">Fire DMG</span>;<br/>When the attack hits an enemy, Evelyn will use <span style=\"color: #FFFFFF\">Lunalux Garrote</span> to bind the primary target and enter <span style=\"color: #FFFFFF\">Binding Seal</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> during a <span style=\"color: #FFFFFF\">Perfect Dodge</span> to activate:<br/>Use <span style=\"color: #FFFFFF\">Lunalux Garrote</span> to slash surrounding enemies, dealing <span style=\"color: #FF5521\">Fire DMG</span>;<br/>When the attack hits an enemy, Evelyn will use <span style=\"color: #FFFFFF\">Lunalux Garrote</span> to bind the primary target and enter <span style=\"color: #FFFFFF\">Binding Seal</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>"
                ],
