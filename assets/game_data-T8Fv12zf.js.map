                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Kitty Slash<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Unleashes up to 5 slashes, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>On the last hit, there is a 33.33% chance to repeat this hit 3 times.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Unleashes up to 5 slashes, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>On the last hit, there is a 33.33% chance to repeat this hit 3 times.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Crimson Blade<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> during the first 3 hits of Nekomata's <span style=\"color: #FFFFFF\">Basic Attack</span> to activate:<br/>Slashes enemies in front and passes through them, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Upon activation, there is a 33.33% chance to repeat this attack 3 times.<!-- --></span><!--]--><!-- --></p></div>",
