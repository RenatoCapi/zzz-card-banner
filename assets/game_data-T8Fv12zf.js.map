        "coreSkill": {
            "desc": [
                "<div class=\"flex flex-col gap-2.5 text-sm leading-4\"><!--[--><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Core Passive: Special Ops Ammunition<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->When Zhu Yuan is under <span style=\"color: #FFFFFF\">Suppressive Mode</span>, using <span style=\"color: #FFFFFF\">Enhanced Shotshells</span> increases her DMG by <span style=\"color: #2BAD00\">40%</span>. When attacking Stunned enemies, this DMG buff is increased by an additional <span style=\"color: #2BAD00\">40%</span>. When Zhu Yuan enters the battlefield, she immediately gains 6 <span style=\"color: #FFFFFF\">Enhanced Shotshells</span>.<!-- --></span><!--]--><!-- --></p></div><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Additional Ability: Tactical Coordination<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->When another character in your squad is a <span style=\"color: #FFFFFF\">Support</span> character or shares the same Faction:<br/>Zhu Yuan's CRIT Rate is increased by 30% for 10s after using an <span style=\"color: #FFFFFF\">EX Special Attack</span>, <span style=\"color: #FFFFFF\">Chain Attack</span>, or <span style=\"color: #FFFFFF\">Ultimate</span>.<!-- --></span><!--]--><!-- --></p></div><!--]--><!-- --></div>"
            ],
            "coreGrowthStat": {
                "21101": 96000,
                "12101": 25
            }
        }
    },
