            "1": {
                "skillId": 1,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Special Attack: Song of Silver Wings<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to activate:<br/>Quickly attack forward, dealing <span style=\"color: #F0D12B\">Physical DMG</span> and <span style=\"color: #FE437E\">Ether DMG</span>.<br/>Anti-Interrupt level is increased while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to activate:<br/>Quickly attack forward, dealing <span style=\"color: #F0D12B\">Physical DMG</span> and <span style=\"color: #FE437E\">Ether DMG</span>.<br/>Anti-Interrupt level is increased while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->EX Special Attack: Violet Requiem<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->With enough Energy, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to activate:<br/>Unleash a powerful forward attack that deals massive <span style=\"color: #FE437E\">Ether DMG</span> and grants 3 <span style=\"color: #FFFFFF\">Flight Feathers</span>.<br/>Character is invulnerable while using this skill.<br/>Enter the <span style=\"color: #FFFFFF\">Fluttering Frock</span> state after using the skill. Hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/5161803192951478865_250_13063804.webp\"/> during the skill to enter the <span style=\"color: #FFFFFF\">Noblewoman</span> state.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->With enough Energy, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to activate:<br/>Unleash a powerful forward attack that deals massive <span style=\"color: #FE437E\">Ether DMG</span> and grants 3 <span style=\"color: #FFFFFF\">Flight Feathers</span>.<br/>Character is invulnerable while using this skill.<br/>Enter the <span style=\"color: #FFFFFF\">Fluttering Frock</span> state after using the skill. Hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/5161803192951478865_250_13063804.webp\"/> during the skill to enter the <span style=\"color: #FFFFFF\">Noblewoman</span> state.<!-- --></span>"
                ],
