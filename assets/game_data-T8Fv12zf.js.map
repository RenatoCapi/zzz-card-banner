            "6": {
                "skillId": 6,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Quick Assist: Duple Meter Allemande<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When the active character is launched, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2454651411643363052_250_13063804.webp\"/> to activate:<br/>Order Drusilla and Anastella to spin forward and trigger an explosion, dealing <span style=\"color: #2EB6FF\">Electric DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When the active character is launched, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2454651411643363052_250_13063804.webp\"/> to activate:<br/>Order Drusilla and Anastella to spin forward and trigger an explosion, dealing <span style=\"color: #2EB6FF\">Electric DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Evasive Assist: Triple Meter Courante<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When the character on field is about to be attacked, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2454651411643363052_250_13063804.webp\"/> to activate:<br/>Dodges the enemy's attack and activates <span style=\"color: #FFFFFF\">Vital View</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When the character on field is about to be attacked, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2454651411643363052_250_13063804.webp\"/> to activate:<br/>Dodges the enemy's attack and activates <span style=\"color: #FFFFFF\">Vital View</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Assist Follow-Up: Quadruple Meter Gavotte<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> after an <span style=\"color: #FFFFFF\">Evasive Assist</span> to activate:<br/>Order Drusilla and Anastella to push forward and generate an electrical vortex, dealing <span style=\"color: #2EB6FF\">Electric DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> after an <span style=\"color: #FFFFFF\">Evasive Assist</span> to activate:<br/>Order Drusilla and Anastella to push forward and generate an electrical vortex, dealing <span style=\"color: #2EB6FF\">Electric DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>"
