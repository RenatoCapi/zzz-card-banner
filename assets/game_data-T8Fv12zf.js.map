        "coreSkill": {
            "desc": [
                "<div class=\"flex flex-col gap-2.5 text-sm leading-4\"><!--[--><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Core Passive: Hyperfocus<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->After holding or tapping repeatedly, when Corin unleashes a continuous extended slash with her Chainsaw, the skill's DMG increases by <span style=\"color: #2BAD00\">37.5%</span>.<!-- --></span><!--]--><!-- --></p></div><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Additional Ability: Cleanup Assistance<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->When another character in your squad shares the same Attribute or Faction:<br/>Corin deals 35% more DMG to Stunned enemies.<!-- --></span><!--]--><!-- --></p></div><!--]--><!-- --></div>"
