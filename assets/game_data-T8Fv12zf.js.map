            "2": {
                "skillId": 2,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Dodge: Immovable Mountain<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->While attacking, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/5161803192951478865_250_13063804.webp\"/> without moving the joystick to activate:<br/>Banyue enters a defensive stance. If attacked during this time, he parries the enemy's attack and accumulates Daze.<br/>If attacked at the exact moment the skill is activated, a Perfect Block occurs.<br/>Character is invulnerable during a successful parry.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->While attacking, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/5161803192951478865_250_13063804.webp\"/> without moving the joystick to activate:<br/>Banyue enters a defensive stance. If attacked during this time, he parries the enemy's attack and accumulates Daze.<br/>If attacked at the exact moment the skill is activated, a Perfect Block occurs.<br/>Character is invulnerable during a successful parry.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Dodge: Overcome Peaks<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/5161803192951478865_250_13063804.webp\"/> to activate:<br/>A quick dash dodge.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/5161803192951478865_250_13063804.webp\"/> to activate:<br/>A quick dash dodge.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Dodge: Battle Cry<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Rotate the joystick in a half-circle and press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/5161803192951478865_250_13063804.webp\"/> to activate:<br/>Dodges backward and taunts enemies.<br/>After any <span style=\"color: #FFFFFF\">EX Special Attack</span>, follow up with <span style=\"color: #FFFFFF\">Dodge: Battle Cry</span> and quickly execute the required inputs during <span style=\"color: #FFFFFF\">Dodge: Battle Cry</span> to then follow up with the corresponding <span style=\"color: #FFFFFF\">EX Special Attack</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Rotate the joystick in a half-circle and press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/5161803192951478865_250_13063804.webp\"/> to activate:<br/>Dodges backward and taunts enemies.<br/>After any <span style=\"color: #FFFFFF\">EX Special Attack</span>, follow up with <span style=\"color: #FFFFFF\">Dodge: Battle Cry</span> and quickly execute the required inputs during <span style=\"color: #FFFFFF\">Dodge: Battle Cry</span> to then follow up with the corresponding <span style=\"color: #FFFFFF\">EX Special Attack</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Dash Attack: Scattering Sands<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->During a dodge, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/>, or during <span style=\"color: #FFFFFF\">Dodge: Battle Cry</span>, hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Launches beads forward, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>After using this skill, can be followed up with the 2nd hit of <span style=\"color: #FFFFFF\">Basic Attack: Towering Peaks</span> or the 2nd hit of <span style=\"color: #FFFFFF\">Basic Attack: Majestic Summit</span>.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->During a dodge, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/>, or during <span style=\"color: #FFFFFF\">Dodge: Battle Cry</span>, hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Launches beads forward, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>After using this skill, can be followed up with the 2nd hit of <span style=\"color: #FFFFFF\">Basic Attack: Towering Peaks</span> or the 2nd hit of <span style=\"color: #FFFFFF\">Basic Attack: Majestic Summit</span>.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Dodge Counter: Stoneburst<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->After a <span style=\"color: #FFFFFF\">Perfect Dodge</span> is triggered through <span style=\"color: #FFFFFF\">Dodge: Overcome Peaks</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/>, or after a <span style=\"color: #FFFFFF\">Perfect Dodge</span> is triggered though <span style=\"color: #FFFFFF\">Dodge: Battle Cry</span>, hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Launches a forward attack that deals <span style=\"color: #FF5521\">Fire DMG</span>.<br/>After using this skill, can be chained into the 3rd hit of <span style=\"color: #FFFFFF\">Basic Attack: Towering Peaks</span> or the 3rd hit of <span style=\"color: #FFFFFF\">Basic Attack: Majestic Summit</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->After a <span style=\"color: #FFFFFF\">Perfect Dodge</span> is triggered through <span style=\"color: #FFFFFF\">Dodge: Overcome Peaks</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/>, or after a <span style=\"color: #FFFFFF\">Perfect Dodge</span> is triggered though <span style=\"color: #FFFFFF\">Dodge: Battle Cry</span>, hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Launches a forward attack that deals <span style=\"color: #FF5521\">Fire DMG</span>.<br/>After using this skill, can be chained into the 3rd hit of <span style=\"color: #FFFFFF\">Basic Attack: Towering Peaks</span> or the 3rd hit of <span style=\"color: #FFFFFF\">Basic Attack: Majestic Summit</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>"
                ],
