        "skillKit": {
            "0": {
                "skillId": 0,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Razor Wire<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Launch up to five attacks ahead, dealing <span style=\"color: #F0D12B\">Physical DMG</span> and <span style=\"color: #FF5521\">Fire DMG</span>.<br/>When the 5th hit lands against an enemy, Evelyn will use her <span style=\"color: #FFFFFF\">Lunalux Garrote</span> to bind the primary target and enter <span style=\"color: #FFFFFF\">Binding Seal</span>.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Launch up to five attacks ahead, dealing <span style=\"color: #F0D12B\">Physical DMG</span> and <span style=\"color: #FF5521\">Fire DMG</span>.<br/>When the 5th hit lands against an enemy, Evelyn will use her <span style=\"color: #FFFFFF\">Lunalux Garrote</span> to bind the primary target and enter <span style=\"color: #FFFFFF\">Binding Seal</span>.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Passive: Bind<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Evelyn uses her skills to deal DMG to enemies, she will accumulate <span style=\"color: #FFFFFF\">Burning Embers</span>.<br/>When Evelyn consumes <span style=\"color: #FFFFFF\">Burning Embers</span> to activate <span style=\"color: #FFFFFF\">Garrote</span> or consumes <span style=\"color: #FFFFFF\">Decibels</span> to perform an <span style=\"color: #FFFFFF\">Ultimate</span>, she gains 1 <span style=\"color: #FFFFFF\">Burning Tether Point</span>.<br/>Once Evelyn has 3 <span style=\"color: #FFFFFF\">Burning Tether Points</span>, her next use of <span style=\"color: #FFFFFF\">Garrote</span> will consume all <span style=\"color: #FFFFFF\">Burning Tether Points</span> to instead use a lower Interrupt Level version of <span style=\"color: #FFFFFF\">Chain Attack: Lunalux - Snare</span>.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Evelyn uses her skills to deal DMG to enemies, she will accumulate <span style=\"color: #FFFFFF\">Burning Embers</span>.<br/>When Evelyn consumes <span style=\"color: #FFFFFF\">Burning Embers</span> to activate <span style=\"color: #FFFFFF\">Garrote</span> or consumes <span style=\"color: #FFFFFF\">Decibels</span> to perform an <span style=\"color: #FFFFFF\">Ultimate</span>, she gains 1 <span style=\"color: #FFFFFF\">Burning Tether Point</span>.<br/>Once Evelyn has 3 <span style=\"color: #FFFFFF\">Burning Tether Points</span>, her next use of <span style=\"color: #FFFFFF\">Garrote</span> will consume all <span style=\"color: #FFFFFF\">Burning Tether Points</span> to instead use a lower Interrupt Level version of <span style=\"color: #FFFFFF\">Chain Attack: Lunalux - Snare</span>.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Garrote - First Form<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When <span style=\"color: #FFFFFF\">Burning Embers</span> is at 50% or higher, hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> or <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to activate:<br/>Consume 50% <span style=\"color: #FFFFFF\">Burning Embers</span> to use <span style=\"color: #FFFFFF\">Lunalux Garrote</span> to perform a slashing attack, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>During skill activation, Anti-Interrupt level increases, and DMG taken is reduced by 40%.<br/>After using this skill, gain 1 <span style=\"color: #FFFFFF\">Burning Tether Point</span>.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When <span style=\"color: #FFFFFF\">Burning Embers</span> is at 50% or higher, hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> or <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to activate:<br/>Consume 50% <span style=\"color: #FFFFFF\">Burning Embers</span> to use <span style=\"color: #FFFFFF\">Lunalux Garrote</span> to perform a slashing attack, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>During skill activation, Anti-Interrupt level increases, and DMG taken is reduced by 40%.<br/>After using this skill, gain 1 <span style=\"color: #FFFFFF\">Burning Tether Point</span>.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Garrote - Second Form<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When <span style=\"color: #FFFFFF\">Burning Embers</span> is 50% or higher, after using <span style=\"color: #FFFFFF\">Basic Attack: Garrote - First Form</span>, continue to hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> or <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to activate:<br/>Consume 50% <span style=\"color: #FFFFFF\">Burning Embers</span> to use <span style=\"color: #FFFFFF\">Lunalux Garrote</span> to perform a follow-up attack, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>During skill activation, Anti-Interrupt level increases, and DMG taken is reduced by 40%.<br/>After using this skill, gain 1 <span style=\"color: #FFFFFF\">Burning Tether Point</span>.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When <span style=\"color: #FFFFFF\">Burning Embers</span> is 50% or higher, after using <span style=\"color: #FFFFFF\">Basic Attack: Garrote - First Form</span>, continue to hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> or <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to activate:<br/>Consume 50% <span style=\"color: #FFFFFF\">Burning Embers</span> to use <span style=\"color: #FFFFFF\">Lunalux Garrote</span> to perform a follow-up attack, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>During skill activation, Anti-Interrupt level increases, and DMG taken is reduced by 40%.<br/>After using this skill, gain 1 <span style=\"color: #FFFFFF\">Burning Tether Point</span>.<!-- --></span>"
                ],
