            "1": {
                "skillId": 1,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Special Attack: Buckshot Blast<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to activate:<br/>Shoots Ether Buckshots that deal <span style=\"color: #FE437E\">Ether DMG</span>. This can be repeated 3 times by repeatedly pressing <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/>.<br/>Anti-Interrupt level is increased while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to activate:<br/>Shoots Ether Buckshots that deal <span style=\"color: #FE437E\">Ether DMG</span>. This can be repeated 3 times by repeatedly pressing <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/>.<br/>Anti-Interrupt level is increased while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->EX Special Attack: Full Barrage<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->With enough Energy, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to activate:<br/>Shoots a series of Ether Buckshots, that explode and deal massive <span style=\"color: #FE437E\">Ether DMG</span>.<br/>Upon activation, gain 3 <span style=\"color: #FFFFFF\">Enhanced Shotshells</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->With enough Energy, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to activate:<br/>Shoots a series of Ether Buckshots, that explode and deal massive <span style=\"color: #FE437E\">Ether DMG</span>.<br/>Upon activation, gain 3 <span style=\"color: #FFFFFF\">Enhanced Shotshells</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>"
                ],
