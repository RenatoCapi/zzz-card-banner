                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Happy to Be of Service<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Unleashes up to four attacks, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Unleashes up to four attacks, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Basic Attack: Rock, Paper, Scissors<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->After <span style=\"color: #FFFFFF\">EX Special Attack: Rock</span> or <span style=\"color: #FFFFFF\">EX Special Attack: Scissors</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Performs up to two attacks, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>During skill activation, Anti-Interrupt level increases, and DMG taken is reduced by 40%.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->After <span style=\"color: #FFFFFF\">EX Special Attack: Rock</span> or <span style=\"color: #FFFFFF\">EX Special Attack: Scissors</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> to activate:<br/>Performs up to two attacks, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>During skill activation, Anti-Interrupt level increases, and DMG taken is reduced by 40%.<!-- --></span>"
