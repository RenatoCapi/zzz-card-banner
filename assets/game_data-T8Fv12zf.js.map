            "3": {
                "skillId": 3,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Chain Attack: Overheated Barrel<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Perform a spinning attack forward, then fire a laser ahead, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>Upon activating this skill, restore 20 points of Bottled Heat.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Perform a spinning attack forward, then fire a laser ahead, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>Upon activating this skill, restore 20 points of Bottled Heat.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Ultimate: Dance With Fire<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating is at <span style=\"color: #FFFFFF\">Maximum</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to activate:<br/>Perform a spinning attack forward, then fire a laser ahead, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>When leaping into the air, a <span style=\"color: #FFFFFF\">Quick Assist</span> will be triggered. If the <span style=\"color: #FFFFFF\">Quick Assist</span> is activated, Orphie &amp; Magus will extend the laser firing duration.<br/>Upon activating this skill, recover 20 Bottled Heat.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating is at <span style=\"color: #FFFFFF\">Maximum</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to activate:<br/>Perform a spinning attack forward, then fire a laser ahead, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>When leaping into the air, a <span style=\"color: #FFFFFF\">Quick Assist</span> will be triggered. If the <span style=\"color: #FFFFFF\">Quick Assist</span> is activated, Orphie &amp; Magus will extend the laser firing duration.<br/>Upon activating this skill, recover 20 Bottled Heat.<br/>Character is invulnerable while using this skill.<!-- --></span>"
                ],
