            "3": {
                "skillId": 3,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Chain Attack: Comet Gravity<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Launch a series of attacks forward, dealing massive <span style=\"color: #FE437E\">Ether DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Launch a series of attacks forward, dealing massive <span style=\"color: #FE437E\">Ether DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Ultimate: Meteor Shower<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating is at <span style=\"color: #FFFFFF\">Maximum</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to activate:<br/>Launch multiple attacks forward, dealing massive <span style=\"color: #FE437E\">Ether DMG</span>.<br/>Upon activating this skill, Nangong Yu activates <span style=\"color: #FFFFFF\">Ether Veil: Delusion Reprise</span>. While <span style=\"color: #FFFFFF\">Ether Veil: Delusion Reprise</span> is active, all squad members gain an additional 50 ATK for 30s. If Nangong Yu activates <span style=\"color: #FFFFFF\">Ether Veil: Delusion Reprise</span> again, the current <span style=\"color: #FFFFFF\">Ether Veil: Delusion Reprise</span> will first deactivate.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating is at <span style=\"color: #FFFFFF\">Maximum</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to activate:<br/>Launch multiple attacks forward, dealing massive <span style=\"color: #FE437E\">Ether DMG</span>.<br/>Upon activating this skill, Nangong Yu activates <span style=\"color: #FFFFFF\">Ether Veil: Delusion Reprise</span>. While <span style=\"color: #FFFFFF\">Ether Veil: Delusion Reprise</span> is active, all squad members gain an additional 50 ATK for 30s. If Nangong Yu activates <span style=\"color: #FFFFFF\">Ether Veil: Delusion Reprise</span> again, the current <span style=\"color: #FFFFFF\">Ether Veil: Delusion Reprise</span> will first deactivate.<br/>Character is invulnerable while using this skill.<!-- --></span>"
