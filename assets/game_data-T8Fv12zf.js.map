            "1": {
                "skillId": 1,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Special Attack: Gummy Bombardment<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to activate:<br/>Fire a cannon shot forward, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to activate:<br/>Fire a cannon shot forward, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->EX Special Attack: Cavity Alert<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->With enough Energy, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to activate:<br/>Throw a bomb at the enemy, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Upon hitting an enemy with a heavy attack, it inflicts the <span style=\"color: #FFFFFF\">Sweet Scare</span> state.<br/>Gains 2 <span style=\"color: #FFFFFF\">Sugar Points</span> upon activation.<br/>A <span style=\"color: #FFFFFF\">Quick Assist</span> is triggered when this skill hits an enemy.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->With enough Energy, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to activate:<br/>Throw a bomb at the enemy, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Upon hitting an enemy with a heavy attack, it inflicts the <span style=\"color: #FFFFFF\">Sweet Scare</span> state.<br/>Gains 2 <span style=\"color: #FFFFFF\">Sugar Points</span> upon activation.<br/>A <span style=\"color: #FFFFFF\">Quick Assist</span> is triggered when this skill hits an enemy.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->EX Special Attack: Cavity Alert, Right Now!<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->After using <span style=\"color: #FFFFFF\">Dodge Counter: Time for Payback~</span>, <span style=\"color: #FFFFFF\">Quick Assist: Dessert Time</span>, <span style=\"color: #FFFFFF\">Assist Follow-Up: We Have Cookies</span>, or <span style=\"color: #FFFFFF\">Assist Follow-Up: Stuffed Hard Candy Shot</span>, or when a <span style=\"color: #FFFFFF\">Perfect Dodge</span> is triggered, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to activate:<br/>Quickly throw a bomb at the enemy, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>On hitting an enemy with a heavy attack, it inflicts the <span style=\"color: #FFFFFF\">Sweet Scare</span> state.<br/>Gains 2 <span style=\"color: #FFFFFF\">Sugar Points</span> upon activation.<br/>A <span style=\"color: #FFFFFF\">Quick Assist</span> is triggered when this skill hits an enemy.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->After using <span style=\"color: #FFFFFF\">Dodge Counter: Time for Payback~</span>, <span style=\"color: #FFFFFF\">Quick Assist: Dessert Time</span>, <span style=\"color: #FFFFFF\">Assist Follow-Up: We Have Cookies</span>, or <span style=\"color: #FFFFFF\">Assist Follow-Up: Stuffed Hard Candy Shot</span>, or when a <span style=\"color: #FFFFFF\">Perfect Dodge</span> is triggered, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to activate:<br/>Quickly throw a bomb at the enemy, dealing <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>On hitting an enemy with a heavy attack, it inflicts the <span style=\"color: #FFFFFF\">Sweet Scare</span> state.<br/>Gains 2 <span style=\"color: #FFFFFF\">Sugar Points</span> upon activation.<br/>A <span style=\"color: #FFFFFF\">Quick Assist</span> is triggered when this skill hits an enemy.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Sweet Scare<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->The <span style=\"color: #FFFFFF\">Sweet Scare</span> state lasts for <span style=\"color: #2BAD00\">40</span>s, repeated triggers reset the duration.<br/>When an enemy affected by <span style=\"color: #FFFFFF\">Sweet Scare</span> is first hit by an active character using an attack of their attribute, <span style=\"color: #FFFFFF\">Flavor Match</span> is triggered against that enemy, changing the attribute of <span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles</span> and <span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles - Max</span> against that enemy to match that of the character who triggered Flavor Match.<br/>When <span style=\"color: #FFFFFF\">Sweet Scare</span> is triggered again on an enemy, their existing <span style=\"color: #FFFFFF\">Flavor Match</span> state is removed. The process can be repeated to change the attribute of <span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles</span> and <span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles - Max</span> again.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->The <span style=\"color: #FFFFFF\">Sweet Scare</span> state lasts for <span style=\"color: #2BAD00\">40</span>s, repeated triggers reset the duration.<br/>When an enemy affected by <span style=\"color: #FFFFFF\">Sweet Scare</span> is first hit by an active character using an attack of their attribute, <span style=\"color: #FFFFFF\">Flavor Match</span> is triggered against that enemy, changing the attribute of <span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles</span> and <span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles - Max</span> against that enemy to match that of the character who triggered Flavor Match.<br/>When <span style=\"color: #FFFFFF\">Sweet Scare</span> is triggered again on an enemy, their existing <span style=\"color: #FFFFFF\">Flavor Match</span> state is removed. The process can be repeated to change the attribute of <span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles</span> and <span style=\"color: #FFFFFF\">Basic Attack: Sugarburst Sparkles - Max</span> again.<!-- --></span>"
                ],
