            "3": {
                "skillId": 3,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Chain Attack: Starfall Intermission<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Unleashes powerful consecutive slashes at enemies ahead, dealing massive <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Unleashes powerful consecutive slashes at enemies ahead, dealing massive <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Ultimate: Starfall Finale<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating is at <span style=\"color: #FFFFFF\">Maximum</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to activate:<br/>Unleashes powerful slashes at enemies in a large area ahead, dealing massive <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Activating this skill restores 200 <span style=\"color: #FFFFFF\">Blade Etiquette</span>.<br/><span style=\"color: #FFFFFF\">Blade Etiquette</span> does not accumulate when hitting an enemy.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating is at <span style=\"color: #FFFFFF\">Maximum</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to activate:<br/>Unleashes powerful slashes at enemies in a large area ahead, dealing massive <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>Activating this skill restores 200 <span style=\"color: #FFFFFF\">Blade Etiquette</span>.<br/><span style=\"color: #FFFFFF\">Blade Etiquette</span> does not accumulate when hitting an enemy.<br/>Character is invulnerable while using this skill.<!-- --></span>"
                ],
