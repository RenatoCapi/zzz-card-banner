        "coreSkill": {
            "desc": [
                "<div class=\"flex flex-col gap-2.5 text-sm leading-4\"><!--[--><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Core Passive: Steady Shot<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->Billy's DMG increases by <span style=\"color: #2BAD00\">50%</span> when he enters Crouching Shot during his <span style=\"color: #FFFFFF\">Basic Attack</span>. The effect ends if he moves, returns to standby, or is knocked back or launched by an attack.<!-- --></span><!--]--><!-- --></p></div><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Additional Ability: Team Starlight<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->When another character in your squad shares the same Attribute or Faction:<br/>After Billy uses a <span style=\"color: #FFFFFF\">Chain Attack</span>, the DMG of his next <span style=\"color: #FFFFFF\">Ultimate</span> is increased by 50%, stacking up to 2 times. This effect resets whenever an <span style=\"color: #FFFFFF\">Ultimate</span> is activated.<!-- --></span><!--]--><!-- --></p></div><!--]--><!-- --></div>"
            ],
            "coreGrowthStat": {
                "20101": 48000,
                "12101": 25
            }
        }
    },
