            "3": {
                "skillId": 3,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Chain Attack: Welcome Mat<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Launches consecutive kicks against enemies in front, dealing massive <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>After using this skill, can immediately follow up with the 4th hit of <span style=\"color: #FFFFFF\">Basic Attack: Happy to Be of Service</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Launches consecutive kicks against enemies in front, dealing massive <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>After using this skill, can immediately follow up with the 4th hit of <span style=\"color: #FFFFFF\">Basic Attack: Happy to Be of Service</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Ultimate: Service Stopped for Number Dialed<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating is at <span style=\"color: #FFFFFF\">Maximum</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to activate:<br/>Rushes forward and performs a finger flick attack, dealing massive <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>After using this skill, can immediately follow up with the 4th hit of <span style=\"color: #FFFFFF\">Basic Attack: Happy to Be of Service</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating is at <span style=\"color: #FFFFFF\">Maximum</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to activate:<br/>Rushes forward and performs a finger flick attack, dealing massive <span style=\"color: #F0D12B\">Physical DMG</span>.<br/>After using this skill, can immediately follow up with the 4th hit of <span style=\"color: #FFFFFF\">Basic Attack: Happy to Be of Service</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>"
                ],
