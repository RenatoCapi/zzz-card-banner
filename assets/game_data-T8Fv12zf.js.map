            "3": {
                "skillId": 3,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Chain Attack: Spring's Call<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Unleashes a powerful slash at enemies in front in a large area, dealing massive <span style=\"color: #98EFF0\">Frost DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Unleashes a powerful slash at enemies in front in a large area, dealing massive <span style=\"color: #98EFF0\">Frost DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Ultimate: Lingering Snow<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating is at <span style=\"color: #FFFFFF\">Maximum</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to activate:<br/>Unleashes powerful slashes at enemies ahead in a large area then pauses, before unleashing a Finishing Move, dealing massive <span style=\"color: #98EFF0\">Frost DMG</span>.<br/>Upon activating this skill, gain 3 points of <span style=\"color: #FFFFFF\">Fallen Frost</span> and increase <span style=\"color: #98EFF0\">Ice DMG</span> by 30% for 12s.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating is at <span style=\"color: #FFFFFF\">Maximum</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to activate:<br/>Unleashes powerful slashes at enemies ahead in a large area then pauses, before unleashing a Finishing Move, dealing massive <span style=\"color: #98EFF0\">Frost DMG</span>.<br/>Upon activating this skill, gain 3 points of <span style=\"color: #FFFFFF\">Fallen Frost</span> and increase <span style=\"color: #98EFF0\">Ice DMG</span> by 30% for 12s.<br/>Character is invulnerable while using this skill.<!-- --></span>"
                ],
