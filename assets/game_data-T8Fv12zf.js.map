            "1": {
                "skillId": 1,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Special Attack: Blazing Chamber<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to activate:<br/>Thrust forward and perform a tail attack, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>Anti-Interrupt level is increased while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to activate:<br/>Thrust forward and perform a tail attack, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>Anti-Interrupt level is increased while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Special Attack: Corrosive Flash<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Automatically triggers during ally attacks:<br/>Unleashes 4 laser Aftershock attacks, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>Triggers once per 5s.<br/>Upon activating this skill, restore 20 Bottled Heat.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Automatically triggers during ally attacks:<br/>Unleashes 4 laser Aftershock attacks, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>Triggers once per 5s.<br/>Upon activating this skill, restore 20 Bottled Heat.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->EX Special Attack: Watch Your Step<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->With enough Energy, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to activate:<br/>Perform a sweeping laser attack forward, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>After using this skill, immediately follow up with the powerful fire blade from the Basic Attack.<br/>Upon activating this skill, restore 20 Bottled Heat.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->With enough Energy, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2297531228866436950_250_13063804.webp\"/> to activate:<br/>Perform a sweeping laser attack forward, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>After using this skill, immediately follow up with the powerful fire blade from the Basic Attack.<br/>Upon activating this skill, restore 20 Bottled Heat.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->EX Special Attack: Crimson Vortex<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When off-field with 60 or more Energy, automatically triggers during ally attacks:<br/>Performs a sweeping laser attack in an area around, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>Upon activating this skill, restore 20 Bottled Heat.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When off-field with 60 or more Energy, automatically triggers during ally attacks:<br/>Performs a sweeping laser attack in an area around, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>Upon activating this skill, restore 20 Bottled Heat.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->EX Special Attack: Heat Charge<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Bottled Heat is greater than or equal to 100, hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to activate:<br/>Consume 100 Bottled Heat to continuously fire a laser forward, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>When firing begins, triggers <span style=\"color: #FFFFFF\">Quick Assist</span>.<br/>After continuous firing for a period, firepower increases, greatly boosting the skill's Interrupt Level.<br/>When attacked during firing, will parry enemy attacks and immediately increase firepower.<br/>When maximum firing duration is reached, automatically activates EX Special Attack: Fiery Eruption.<br/>During the low firepower phase, Anti-Interrupt Level increases and DMG taken is reduced by 40%, while character is invulnerable during the high firepower phase.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Bottled Heat is greater than or equal to 100, hold <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1001669963319182284_250_13063804.webp\"/> to activate:<br/>Consume 100 Bottled Heat to continuously fire a laser forward, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>When firing begins, triggers <span style=\"color: #FFFFFF\">Quick Assist</span>.<br/>After continuous firing for a period, firepower increases, greatly boosting the skill's Interrupt Level.<br/>When attacked during firing, will parry enemy attacks and immediately increase firepower.<br/>When maximum firing duration is reached, automatically activates EX Special Attack: Fiery Eruption.<br/>During the low firepower phase, Anti-Interrupt Level increases and DMG taken is reduced by 40%, while character is invulnerable during the high firepower phase.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->EX Special Attack: Fiery Eruption<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Automatically activates after EX Special Attack: Heat Charge reaches maximum firing time:<br/>Performs a spinning attack forward, then fires a laser ahead dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Automatically activates after EX Special Attack: Heat Charge reaches maximum firing time:<br/>Performs a spinning attack forward, then fires a laser ahead dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>"
                ],
