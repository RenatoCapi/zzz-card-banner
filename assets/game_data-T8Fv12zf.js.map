        ],
        "id": "1431",
        "growthStat": {
            "11101": {
                "base": 617,
                "growth": 837458,
                "asc": 423
            },
            "12101": {
                "base": 135,
                "growth": 82712,
                "asc": 48
            },
            "13101": {
