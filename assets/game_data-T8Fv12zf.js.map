            "6": {
                "skillId": 6,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Quick Assist: Fierce Blade<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When the active character is launched, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2454651411643363052_250_13063804.webp\"/> to activate:<br/>Use <span style=\"color: #FFFFFF\">Lunalux Garrote</span> to slash surrounding enemies, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>When the attack hits an enemy, Evelyn will use <span style=\"color: #FFFFFF\">Lunalux Garrote</span> to bind the primary target and enter <span style=\"color: #FFFFFF\">Binding Seal</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When the active character is launched, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2454651411643363052_250_13063804.webp\"/> to activate:<br/>Use <span style=\"color: #FFFFFF\">Lunalux Garrote</span> to slash surrounding enemies, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>When the attack hits an enemy, Evelyn will use <span style=\"color: #FFFFFF\">Lunalux Garrote</span> to bind the primary target and enter <span style=\"color: #FFFFFF\">Binding Seal</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Defensive Assist: Silent Protection<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When the on-field character is about to be attacked, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2454651411643363052_250_13063804.webp\"/> to activate:<br/>Parries the enemy's attack, dealing massive Daze.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When the on-field character is about to be attacked, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2454651411643363052_250_13063804.webp\"/> to activate:<br/>Parries the enemy's attack, dealing massive Daze.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Assist Follow-Up: Course Disruption<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> after a <span style=\"color: #FFFFFF\">Defensive Assist</span> to activate:<br/>Evelyn slashes with <span style=\"color: #FFFFFF\">Lunalux Garrote</span>, then triggers an explosion ahead, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>When the attack hits an enemy, Evelyn will use <span style=\"color: #FFFFFF\">Lunalux Garrote</span> to bind the primary target and enter <span style=\"color: #FFFFFF\">Binding Seal</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> after a <span style=\"color: #FFFFFF\">Defensive Assist</span> to activate:<br/>Evelyn slashes with <span style=\"color: #FFFFFF\">Lunalux Garrote</span>, then triggers an explosion ahead, dealing <span style=\"color: #FF5521\">Fire DMG</span>.<br/>When the attack hits an enemy, Evelyn will use <span style=\"color: #FFFFFF\">Lunalux Garrote</span> to bind the primary target and enter <span style=\"color: #FFFFFF\">Binding Seal</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>"
                ],
