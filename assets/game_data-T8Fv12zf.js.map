        "coreSkill": {
            "desc": [
                "<div class=\"flex flex-col gap-2.5 text-sm leading-4\"><!--[--><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Core Passive: Brothers in Arms!<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->When Anton uses his <span style=\"color: #FFFFFF\">Piledriver Attack</span>, the skill's DMG is increased by <span style=\"color: #2BAD00\">24%</span> and when he uses his <span style=\"color: #FFFFFF\">Drill Attack</span>, the skill's DMG is increased by <span style=\"color: #2BAD00\">40%</span>.<!-- --></span><!--]--><!-- --></p></div><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Additional Ability: Teamwork<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->When another character in your squad shares the same Attribute or Faction:<br/>While Anton is in <span style=\"color: #FFFFFF\">Burst Mode</span>, for every 4 critical hits, the next attack hitting <span style=\"color: #2EB6FF\">Shocked</span> enemies triggers an additional bout of <span style=\"color: #2EB6FF\">Shock</span> DMG at 45% of the original DMG. This effect can trigger once every 0.5s.<!-- --></span><!--]--><!-- --></p></div><!--]--><!-- --></div>"
            ],
            "coreGrowthStat": {
                "20101": 48000,
                "12101": 25
            }
        }
    },
