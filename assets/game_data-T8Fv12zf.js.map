            "3": {
                "skillId": 3,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Chain Attack: Go Go Go!<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Unleashes a <span style=\"color: #FFFFFF\">Piledriver Attack</span> onto the ground in front of him over a large area, dealing massive <span style=\"color: #2EB6FF\">Electric DMG</span> to enemies within range.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Unleashes a <span style=\"color: #FFFFFF\">Piledriver Attack</span> onto the ground in front of him over a large area, dealing massive <span style=\"color: #2EB6FF\">Electric DMG</span> to enemies within range.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Ultimate: Go Go Go Go Go!<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating is at <span style=\"color: #FFFFFF\">Maximum</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to activate:<br/>Unleashes a <span style=\"color: #FFFFFF\">Piledriver Attack</span> onto the ground in front of him over a large area, dealing massive <span style=\"color: #2EB6FF\">Electric DMG</span> to enemies within range.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating is at <span style=\"color: #FFFFFF\">Maximum</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to activate:<br/>Unleashes a <span style=\"color: #FFFFFF\">Piledriver Attack</span> onto the ground in front of him over a large area, dealing massive <span style=\"color: #2EB6FF\">Electric DMG</span> to enemies within range.<br/>Character is invulnerable while using this skill.<!-- --></span>"
                ],
