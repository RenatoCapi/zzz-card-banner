            "3": {
                "skillId": 3,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Chain Attack: Blazing Wrath<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Launches a large area attack in front, dealing massive <span style=\"color: #FF5521\">Fire DMG</span>.<br/>If Banyue has more than 120 <span style=\"color: #FFFFFF\">Wrathful Fires</span>, he automatically enters the <span style=\"color: #FFFFFF\">Visage of Wrath</span> state after the attack.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Launches a large area attack in front, dealing massive <span style=\"color: #FF5521\">Fire DMG</span>.<br/>If Banyue has more than 120 <span style=\"color: #FFFFFF\">Wrathful Fires</span>, he automatically enters the <span style=\"color: #FFFFFF\">Visage of Wrath</span> state after the attack.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Ultimate: The World Trembles<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating is at <span style=\"color: #FFFFFF\">Maximum</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to activate:<br/>Launches a large area attack in front, dealing massive <span style=\"color: #FF5521\">Fire DMG</span>.<br/>If Banyue has more than 120 <span style=\"color: #FFFFFF\">Wrathful Fires</span>, he automatically enters the <span style=\"color: #FFFFFF\">Visage of Wrath</span> state after the attack.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating is at <span style=\"color: #FFFFFF\">Maximum</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to activate:<br/>Launches a large area attack in front, dealing massive <span style=\"color: #FF5521\">Fire DMG</span>.<br/>If Banyue has more than 120 <span style=\"color: #FFFFFF\">Wrathful Fires</span>, he automatically enters the <span style=\"color: #FFFFFF\">Visage of Wrath</span> state after the attack.<br/>Character is invulnerable while using this skill.<!-- --></span>"
                ],
