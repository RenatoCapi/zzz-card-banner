        "coreSkill": {
            "desc": [
                "<div class=\"flex flex-col gap-2.5 text-sm leading-4\"><!--[--><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Core Passive: Guardian<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->Ben's initial ATK increases along with his initial DEF. He gains <span style=\"color: #2BAD00\">80%</span> of his initial DEF as ATK.<br/>When Ben launches a powerful follow-up strike during his <span style=\"color: #FFFFFF\">EX Special Attack</span>, all squad members gain a Shield of <span style=\"color: #2BAD00\">30%</span> of his DEF +<span style=\"color: #2BAD00\">550</span>, lasting for 30s.<!-- --></span><!--]--><!-- --></p></div><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Additional Ability: Contractual Agreement<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->When another character in your squad shares the same Attribute or Faction:<br/>While the Shield from <span style=\"color: #FFFFFF\">Core Passive: Guardian</span> is in effect, the character's CRIT Rate is increased by 16%.<!-- --></span><!--]--><!-- --></p></div><!--]--><!-- --></div>"
            ],
