            "3": {
                "skillId": 3,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Chain Attack: Anointed with Wok Steam<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Hop onto the Iron Wok and spin rapidly to ram into enemies, dealing massive <span style=\"color: #F0D12B\">Physical DMG</span> to all enemies on the way.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Hop onto the Iron Wok and spin rapidly to ram into enemies, dealing massive <span style=\"color: #F0D12B\">Physical DMG</span> to all enemies on the way.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Ultimate: A Feast Fit for an Emperor!<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating is at <span style=\"color: #FFFFFF\">Maximum</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to activate:<br/>Perform a technique that compresses qi into fried rice and catapults it at foes, dealing massive <span style=\"color: #F0D12B\">Physical DMG</span> and healing all squad members for <span style=\"color: #2BAD00\">820</span> HP, while also applying a 8s heal over time on all squad members, recovering <span style=\"color: #2BAD00\">1.4</span>% HP/s.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating is at <span style=\"color: #FFFFFF\">Maximum</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to activate:<br/>Perform a technique that compresses qi into fried rice and catapults it at foes, dealing massive <span style=\"color: #F0D12B\">Physical DMG</span> and healing all squad members for <span style=\"color: #2BAD00\">820</span> HP, while also applying a 8s heal over time on all squad members, recovering <span style=\"color: #2BAD00\">1.4</span>% HP/s.<br/>Character is invulnerable while using this skill.<!-- --></span>"
                ],
