        "coreSkill": {
            "desc": [
                "<div class=\"flex flex-col gap-2.5 text-sm leading-4\"><!--[--><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Core Passive: Stealthy Paws<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->When Nekomata's <span style=\"color: #FFFFFF\">Dodge Counter</span> or <span style=\"color: #FFFFFF\">Quick Assist</span> hits an enemy, her DMG increases by <span style=\"color: #2BAD00\">60%</span> for 6s.<!-- --></span><!--]--><!-- --></p></div><div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Additional Ability: Catwalk<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm zzz-fmt\"><!-- -->When another character in your squad shares the same Attribute or Faction:<br/>After any character inflicts <span style=\"color: #F0D12B\">Assault</span>, increases the DMG of Nekomata's next <span style=\"color: #FFFFFF\">EX Special Attack</span> by 35%, stacking up to 2 times.<!-- --></span><!--]--><!-- --></p></div><!--]--><!-- --></div>"
            ],
            "coreGrowthStat": {
                "20101": 48000,
                "12101": 25
            }
        }
    },
