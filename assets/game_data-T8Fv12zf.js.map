            "3": {
                "skillId": 3,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Chain Attack: Avalanche<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Crash down from above and unleash an ice storm, dealing massive <span style=\"color: #98EFF0\">Ice DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When a <span style=\"color: #FFFFFF\">Chain Attack</span> is triggered, select the character to activate:<br/>Crash down from above and unleash an ice storm, dealing massive <span style=\"color: #98EFF0\">Ice DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Ultimate: Endless Winter<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating is at <span style=\"color: #FFFFFF\">Maximum</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to activate:<br/>Crash down from above and unleash an ice storm before a powerful scissor strike, dealing massive <span style=\"color: #98EFF0\">Ice DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When Decibel Rating is at <span style=\"color: #FFFFFF\">Maximum</span>, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/1387329758178637252_250_13063804.webp\"/> to activate:<br/>Crash down from above and unleash an ice storm before a powerful scissor strike, dealing massive <span style=\"color: #98EFF0\">Ice DMG</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>"
                ],
