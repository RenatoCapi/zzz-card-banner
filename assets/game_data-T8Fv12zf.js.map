            "6": {
                "skillId": 6,
                "desc": [
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Quick Assist: Crushing Mist<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When the active character is launched, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2454651411643363052_250_13063804.webp\"/> to activate:<br/>This Quick Assist is a <span style=\"color: #FFFFFF\">Whim</span>. When activated, it summons an Ethereal figure that delivers a downward attack in a circular area ahead, dealing <span style=\"color: #FE437E\">Ether DMG</span>.<br/>If not in the <span style=\"color: #FFFFFF\">Dream</span> state, Lucia gains 20 <span style=\"color: #FFFFFF\">Dream Points</span> upon using this <span style=\"color: #FFFFFF\">Whim</span>. This effect can trigger once every 5s.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When the active character is launched, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2454651411643363052_250_13063804.webp\"/> to activate:<br/>This Quick Assist is a <span style=\"color: #FFFFFF\">Whim</span>. When activated, it summons an Ethereal figure that delivers a downward attack in a circular area ahead, dealing <span style=\"color: #FE437E\">Ether DMG</span>.<br/>If not in the <span style=\"color: #FFFFFF\">Dream</span> state, Lucia gains 20 <span style=\"color: #FFFFFF\">Dream Points</span> upon using this <span style=\"color: #FFFFFF\">Whim</span>. This effect can trigger once every 5s.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Defensive Assist: Voice of Illusory Dreams<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When the on-field character is about to be attacked, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2454651411643363052_250_13063804.webp\"/> to activate:<br/>Parries the enemy's attack, dealing massive Daze.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->When the on-field character is about to be attacked, press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/2454651411643363052_250_13063804.webp\"/> to activate:<br/>Parries the enemy's attack, dealing massive Daze.<br/>Character is invulnerable while using this skill.<!-- --></span>",
                    "<div class=\"text-sm\"><h4 class=\"font-bold\"><!--[--><span><!-- -->Assist Follow-Up: Harmony of Painted Dreams<!-- --></span><!--]--><!-- --></h4> <p><!--[--><span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> after a <span style=\"color: #FFFFFF\">Defensive Assist</span> to activate:<br/>This Assist Follow-Up is a <span style=\"color: #FFFFFF\">Harmony</span>. When activated, it summons an Ethereal figure that delivers a downward attack in a circular area ahead, dealing <span style=\"color: #FE437E\">Ether DMG</span>.<br/>If not in the <span style=\"color: #FFFFFF\">Dream</span> state, Lucia gains 40 <span style=\"color: #FFFFFF\">Dream Points</span> upon using this <span style=\"color: #FFFFFF\">Harmony</span>.<br/>Character is invulnerable while using this skill.<!-- --></span><!--]--><!-- --></p></div>",
                    "<span class=\"text-sm leading-6 zzz-fmt\"><!-- -->Press <img alt=\"\" class=\"h-6 w-auto inline zzz-inline-icon\" src=\"https://cdn.gachabase.net/prod/zzz/assets/15317334708392014940_250_13063804.webp\"/> after a <span style=\"color: #FFFFFF\">Defensive Assist</span> to activate:<br/>This Assist Follow-Up is a <span style=\"color: #FFFFFF\">Harmony</span>. When activated, it summons an Ethereal figure that delivers a downward attack in a circular area ahead, dealing <span style=\"color: #FE437E\">Ether DMG</span>.<br/>If not in the <span style=\"color: #FFFFFF\">Dream</span> state, Lucia gains 40 <span style=\"color: #FFFFFF\">Dream Points</span> upon using this <span style=\"color: #FFFFFF\">Harmony</span>.<br/>Character is invulnerable while using this skill.<!-- --></span>"
